# Backend URL for quiz generation
VITE_BACKEND_URL=http://localhost:3001

# Faucet contract address (required for claiming rewards — deploy TokoFaucet.sol first, then paste the address here)
# Run: npx hardhat run scripts/deploy.js --network sepolia
VITE_FAUCET_ADDRESS=0x306d689e33b8bB9438dc46B1B225CEF8d7bDA982

# Optional: Your own Sepolia RPC URL (recommended to avoid rate limits)
# Get one for free from dashboard.alchemy.com or infura.io
VITE_SEPOLIA_RPC_URL=
